{
  "name": "blaise-uac-service-ui",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "scripts": {
    "build": "yarn build:client && yarn build:server",
    "build:client": "yarn vite build",
    "build:server": "yarn tsc --project tsconfig.server.build.json",
    "dev": "yarn concurrently --kill-others-on-fail --names \"server,web\" \"yarn dev:server\" \"yarn dev:client\"",
    "dev-wsl": "CHOKIDAR_USEPOLLING=1 CHOKIDAR_INTERVAL=300 yarn concurrently --kill-others-on-fail --names \"server,web\" \"yarn dev-wsl:server\" \"yarn dev-wsl:client\"",
    "dev-wsl:client": "yarn vite --host 0.0.0.0",
    "dev-wsl:server": "yarn run-watch-wsl:server",
    "dev:client": "yarn vite",
    "dev:server": "yarn run-watch:server",
    "gcp-build": "yarn build",
    "kill": "bash -lc 'lsof -ti:3000,5000,8080 | xargs -r kill -9 2>/dev/null || true; pkill -f concurrently 2>/dev/null || true'",
    "lint": "yarn typecheck && yarn eslint . --max-warnings 0 && yarn prettier --check . && yarn knip",
    "lint-fix": "yarn eslint . --fix && yarn prettier --write . && yarn knip --fix",
    "run-watch-wsl:server": "tsx watch src/server/index.ts | yarn pino-pretty -c -t",
    "run-watch:server": "tsx watch src/server/index.ts | yarn pino-pretty -c -t",
    "spellcheck": "yarn cspell \"**/*.{ts,tsx,json,jsonc,yml,yaml,md}\" --no-progress --no-summary",
    "start": "node ./build/server/index.js",
    "test": "yarn vitest run --coverage",
    "test-watch": "yarn vitest",
    "typecheck": "yarn tsc --noEmit -p tsconfig.client.json && yarn tsc --noEmit -p tsconfig.server.json && yarn tsc --noEmit -p tsconfig.tooling.json"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@tanstack/react-query": "^5.101.0",
    "axios": "^1.17.0",
    "blaise-api-node-client": "git+https://github.com/ONSdigital/blaise-api-node-client#BLAIS5-5177",
    "blaise-design-system-react-components": "git+https://github.com/ONSdigital/blaise-design-system-react-components#BLAIS5-5177",
    "blaise-login-react-client": "git+https://github.com/ONSdigital/blaise-login-react.git#head=BLAIS5-5177&workspace=blaise-login-react-client",
    "blaise-login-react-server": "git+https://github.com/ONSdigital/blaise-login-react.git#head=BLAIS5-5177&workspace=blaise-login-react-server",
    "blaise-uac-service-node-client": "git+https://github.com/ONSdigital/blaise-uac-service-node-client#BLAIS5-5177",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "fast-csv": "^5.0.7",
    "formik": "^2.4.9",
    "multer": "^2.1.1",
    "pino-http": "^11.0.0",
    "react": "^19.2.7",
    "react-csv-downloader": "^3.3.0",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.16.0",
    "typescript": "~6.0.3"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.8.10",
    "@eslint/js": "^10.0.1",
    "@jest-mock/express": "^3.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "axios-mock-adapter": "^2.1.0",
    "concurrently": "^10.0.3",
    "cspell": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsonc": "^3.2.0",
    "express-list-endpoints": "^7.1.1",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "jsonc-eslint-parser": "^3.1.0",
    "knip": "^6.15.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "packageManager": "yarn@4.14.1"
}
