            >
              <div
                class="ons-grid"
              >
                <div
                  class="ons-grid__col ons-col-8@m"
                >
                  <h1>
                    Which used UAC file do you want to upload?
                  </h1>
                  <div
                    class="ons-panel ons-panel--info ons-panel--no-title ons-u-mt-m"
                    id="panel-_r_0_"
                  >
                    <span
                      class="ons-panel__assistive-text ons-u-vh"
                    >
                      Important information:
                       
                    </span>
                    <div
                      class="ons-panel__body "
                    >
                      <p>
                        The UAC file must be a CSV containing the column
                         
                        <em
                          class="ons-highlight"
                        >
                          UAC
                        </em>
                        .
                      </p>
                      <p>
                        Upload UACs that were generated outside this service or the Deploy Questionnaire Service (DQS). Uploading these UACs marks them as used, so they will not be generated again.
                      </p>
                      <p>
                        Upload may take a few minutes. Do not navigate away from this page.
                      </p>
                    </div>
                  </div>
                  <div
                    class="ons-field"
                  >
                    <div
                      class="ons-field"
                    >
                      <label
                        class="ons-label ons-label--with-description"
