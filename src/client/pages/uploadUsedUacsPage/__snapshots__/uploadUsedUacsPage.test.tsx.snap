                      >
                        Select a UAC file
                      </label>
                      <span
                        class="ons-label__description ons-input--with-description"
                        id="uac-selector-hint"
                      >
                        Accepted file type: csv
                      </span>
                      <input
                        accept=".csv"
                        aria-describedby="uac-selector-hint"
                        class="ons-input ons-input--text ons-input-type__input ons-input--upload"
                        data-testid="uac-selector-input"
                        id="uac-selector"
                        name="file"
                        type="file"
                      />
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div
              class="ons-btn-group ons-u-mt-m"
            >
